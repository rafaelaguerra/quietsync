# Copy this file to keystore.properties (gitignored) and fill in your release signing values.
# Generate a keystore with:
#   keytool -genkey -v -keystore release.keystore -alias synctask -keyalg RSA -keysize 2048 -validity 10000
storeFile=release.keystore
storePassword=your-store-password
keyAlias=synctask
keyPassword=your-key-password
