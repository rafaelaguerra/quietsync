    <string name="onboarding_perm_title">Two permissions to make it work</string>
    <string name="onboarding_perm_subtitle">QuietSync only uses what is needed to honor your calendar and switch your phone mode. We never read your private data.</string>
    <string name="onboarding_perm_calendar_title">Calendar access</string>
    <string name="onboarding_perm_calendar_body">So QuietSync can create the event in your calendar and remember when to switch modes.</string>
    <string name="onboarding_perm_mode_title">Mode access for QuietSync</string>
    <string name="onboarding_perm_mode_body">So QuietSync can turn on Do Not Disturb, Silent or Vibrate automatically while your event is running.</string>
    <string name="onboarding_perm_footer">You can grant or revoke these from Android Settings at any time.</string>

    <!-- Permission rationales (shown before sending the user to system settings) -->
    <string name="perm_dialog_calendar_title">Allow access to your calendar</string>
    <string name="perm_dialog_calendar_body">QuietSync needs to read and create events on your calendar so it knows when to apply the right device mode. Tap Continue and choose \"Allow\" in the next screen.</string>
    <string name="perm_dialog_dnd_title">Allow QuietSync to change your phone mode</string>
    <string name="perm_dialog_dnd_body">To put your phone in Do Not Disturb, Silent or Vibrate automatically, QuietSync needs the \"Do Not Disturb access\" permission.\n\n1. Tap Open settings.\n2. Find QuietSync in the list.\n3. Turn on the switch.</string>
